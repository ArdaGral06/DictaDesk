{
  "providers": [
    {
      "id": "openai",
      "label": "OpenAI TTS (gpt-4o-mini-tts, tts-1-hd, …)",
      "endpoint": "https://api.openai.com/v1/audio/speech",
      "headers": {
        "Authorization": "Bearer {api_key}",
        "Content-Type": "application/json"
      },
      "response_format": "mp3",
      "model_field": "model",
      "json": {
        "model": "gpt-4o-mini-tts",
        "input": "{text}",
        "voice": "alloy"
      },
      "timeout_sec": 60
    },
    {
      "id": "elevenlabs",
      "label": "ElevenLabs (multilingual, voice cloning)",
      "endpoint": "https://api.elevenlabs.io/v1/text-to-speech/{voice_id}",
      "headers": {
        "xi-api-key": "{api_key}",
        "accept": "audio/mpeg",
        "content-type": "application/json"
      },
      "query": {
        "output_format": "mp3_44100_128"
      },
      "response_format": "mp3",
      "model_field": "model_id",
      "json": {
        "text": "{text}",
        "voice_settings": {
          "stability": 0.5,
          "similarity_boost": 0.75
        }
      }
    },
    {
      "id": "together",
      "label": "Together AI TTS (Kokoro, Cartesia Sonic-3, Orpheus, …)",
      "endpoint": "https://api.together.ai/v1/audio/speech",
      "headers": {
        "Authorization": "Bearer {api_key}",
        "Content-Type": "application/json"
      },
      "response_format": "mp3",
      "model_field": "model",
      "json": {
        "model": "hexgrad/Kokoro-82M",
        "input": "{text}",
        "voice": "af_alloy",
        "response_format": "mp3"
      },
      "timeout_sec": 60
    },
    {
      "id": "custom",
      "label": "Custom (edit tts_providers.json)",
      "endpoint": "",
      "headers": {
        "Authorization": "Bearer {api_key}"
      },
      "response_format": "wav",
      "json": {
        "text": "{text}"
      }
    }
  ]
}
